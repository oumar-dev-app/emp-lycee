{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/actualite/layout,_N_T_/actualite/page,_N_T_/actualite"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/actualite/__PAGE__",
    "/actualite",
    "/_index",
    "/_head"
  ]
}